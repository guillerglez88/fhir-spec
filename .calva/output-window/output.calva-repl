      :id "VirtualServiceDetail.maxParticipants",
      :comment
      "Some services have only a limitted number of participants permitted to connect at a time, this is typically used in \"shared\" virtual services that you might find on location resources.\n\nTypically on-demand services might not have these restrictions.",
      :base {:path "VirtualServiceDetail.maxParticipants", :min 0, :max "1"},
