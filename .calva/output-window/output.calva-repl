      :mapping [{:identity "v2", :map "DR.1"} {:identity "rim", :map "./low"}],
      :type [{:code "dateTime"}],
      :max "1",
      :id "Period.start",
      :condition ["per-1"],
      :comment "If the low element is missing, the meaning is that the low boundary is not known.",
      :base {:path "Period.start", :min 0, :max "1"},
      :isSummary true}
     {:constraint
      [{:key "ele-1",
        :severity "error",
